#仇仇及楮醒反32,64徆杅井日銀迕今木月﹝
#arch戊穴件玉及請恘午BIN32互啜丹樺寧反64棕雁匹丐月午仄化32申永玄迕及犯奴伊弁玄伉毛勾仁月﹝

arch=$(shell $(ARCH))
subdirs=$(arch)

ifneq "$(arch)" "$(BIN32)"
subdirs+=$(BIN32)

#32申永玄迕犯奴伊弁玄伉
$(BIN32):
	mkdir $(BIN32)
	ln -s ../Makefile32 $(BIN32)/Makefile
endif


#仇及穴扑件迕田奶瓜伉及犯奴伊弁玄伉
$(arch):
	mkdir $(arch)
	ln -s ../Makefile.com $(arch)/Makefile

include ../def.mk

all install uninstall depend: $(subdirs)
	$(callsubmake)

clean:
	rm -rf $(subdirs)
