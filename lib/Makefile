#仇仇及楮醒反32,64徆杅井日銀迕今木月﹝
#WOW64互1及午五$(BIN32NAME)/卞32bit及田奶瓜伉互請恘今木月﹝

include ../conf.mk
override CFLAGS+=-fPIC

#$(BIN32NAME)井日裟壬木凶午五迕
vpath %.c ..
vpath %.h ..

app=libwimeut.a
objs=ut.o array.o link.o list.o wimeconn.o log.o

ifeq ($(WOW64) , 1)
app2=$(BIN32NAME)
endif

ifeq ($(FREEBSD) , 1)
objs+=freebsd.o
endif

include ../def.mk

install:

uninstall:

$(app):$(objs)
	ar rcs $@ $^

.PHONY:$(BIN32NAME)
$(BIN32NAME):
	mkdir -p $@
	$(MAKE) -C $@ -f ../Makefile WOW64=0 CC="$(CC32_ENV) $(CC)" CFLAGS="$(CFLAGS) -m32" -I ..
