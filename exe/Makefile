include ../conf.mk

override CFLAGS+=-fno-builtin -mconsole -DLOGMARK=SERVER_MARK -DWIME_VERSION=$(VERSION) -I..
override LDFLAGS+=-limm32 -lgdi32 -lrt -lpthread
override CC=winegcc

ifeq ($(WINE32) , 1)
override CFLAGS+=-m32
override LDFLAGS+=-m32
endif

ifeq ($(FREEBSD),1)
#/usr/local/include互卅中午canna/RK.h互づ心慇引木卅中﹝
#允屯化及CFLAGS卞/usr/local/include毛勾仃月午/usr/local/include及iconv.h互銀歹木化仄引丹﹝
#午中丹仇午匹﹜exe及戊件由奶伙凜及心local毛勾仃月﹝
#-mno-cygwin卅仄匹扑旦氾丞及目永母白央奶伙毛銀丹午WCHAR互4田奶玄卞卅勻化仄引丹﹝
override CFLAGS+=-I/usr/local/include -mno-cygwin
override LDFLAGS+=-mno-cygwin
endif

app=wime.exe.so
objs=apisup.o canna.o main.o at.o
solibs=../io/libwimeio.so

exename=$(basename $(app))	# .so卅仄
app2=$(basename $(exename))	# .exe.so卅仄

include ../def.mk

#wine1.1.16匹反winegcc反請恘白央奶伙抩卞啦譁匹手傀艦閡毛尥仃月心凶中﹝
#傀艦閡互卅仃木壬exe毛勾仃化foo.exe午foo.exe.so毛請恘仄﹜
#窒井傀艦閡互丐木壬foo.ext午foo.ext.so毛請恘允月﹝
#16動曉卅日wime.exe毛wime卞庍凳允月﹝
winever=$(word 1,$(sort $(word 1,$(shell wine --version)) wine-1.1.16))
ifeq ($(winever),wine-1.1.16)	
renamecmd=mv
else
renamecmd=:
endif


$(app):$(objs) $(libwimeutarch) $(solibs)
	$(CC) -o $(app2) $(objs) $(libwimeutarch) $(LDFLAGS)
	$(renamecmd) $(exename) $(app2)

install:
	$(MKDIRP) $(PREFIX)/bin
	$(INSTALL) $(app) $(app2) $(PREFIX)/bin

uninstall:
	$(RM) $(PREFIX)/bin/$(app)
	$(RM) $(PREFIX)/bin/$(app2)
