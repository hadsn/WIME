include ../conf.mk

override CFLAGS+=-fno-builtin -mconsole -DWIME_VERSION=$(VERSION) -I..
override LDFLAGS+=-limm32 -lgdi32 -lrt -lpthread
override CC=winegcc

ifeq ($(WOW64) , 1)
override CC:=$(CC32_ENV) $(CC)
override CFLAGS+=-m32
override LDFLAGS+=-m32
endif

ifeq ($(FREEBSD),1)

#/usr/local/include§¨§ §§§»canna/RK.h§¨∆…§ŖĻĢ§ř§ž§ §§°£
#§Ļ§Ŕ§∆§őCFLAGS§ň/usr/local/include§Ú§ń§Ī§Ž§»/usr/local/include§őiconv.h§¨Ľ»§Ô§ž§∆§∑§ř§¶°£
#§»§§§¶§≥§»§«°Ęexe§ő•≥•ů•—•§•ŽĽĢ§ő§Ŗlocal§Ú§ń§Ī§Ž°£
override CFLAGS+=-I/usr/local/include

#clang§ő§»§≠§Ō§≥§ž§Ú§ń§Ī§ §§§»WCHAR§¨32bit§ň§ §√§∆§∑§ř§¶°£
ifeq ($(USE_CLANG),1)
override CFLAGS+=-fno-short-wchar
endif

endif

app=wime.exe.so
objs=apisup.o canna.o main.o at.o
solibs=../io/libwimeio.so

exename=$(basename $(app))	# .so§ §∑
app2=$(basename $(exename))	# .exe.so§ §∑

include ../def.mk

#wine1.1.16§«§Ōwinegcc§ŌĹ–őŌ•’•°•§•ŽŐĺ§ňį’√Ō§«§‚≥»ń•Ľ“§Ú…’§Ī§Ž§Ŗ§Ņ§§°£
#≥»ń•Ľ“§¨§ §Ī§ž§–exe§Ú§ń§Ī§∆foo.exe§»foo.exe.so§ÚĹ–őŌ§∑°Ę
#≤Ņ§ę≥»ń•Ľ“§¨§Ę§ž§–foo.ext§»foo.ext.so§ÚĹ–őŌ§Ļ§Ž°£
#16į ĺŚ§ §ťwime.exe§Úwime§ň —ĻĻ§Ļ§Ž°£
winever=$(word 1,$(sort $(word 1,$(shell $(WINE) --version)) wine-1.1.16))
ifeq ($(winever),wine-1.1.16)	
renamecmd=mv
else
renamecmd=:
endif


$(app):$(objs) $(libwimeutarch) $(solibs)
	$(CC) $(LDFLAGS) -o $(app2) $(objs) $(libwimeutarch)
	$(renamecmd) $(exename) $(app2)

install:
	$(MKDIRP) $(PREFIX)/bin
	$(INSTALL) $(app) $(app2) $(PREFIX)/bin

uninstall:
	$(RM) $(PREFIX)/bin/$(app)
	$(RM) $(PREFIX)/bin/$(app2)
