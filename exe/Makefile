include ../conf.mk

override CFLAGS+=-fno-builtin -mconsole -mno-cygwin -DLOGMARK=SERVER_MARK -DWIME_VERSION=$(VERSION) -I..
override LDFLAGS+=-limm32 -lgdi32 -mno-cygwin -lrt -lpthread
override CC=winegcc

ifeq ($(WINE32) , 1)
override CFLAGS+=-m32
override LDFLAGS+=-m32
endif

app=wime.exe.so
objs=apisup.o canna.o main.o at.o
solibs=../io/libwimeio.so

exename=$(basename $(app))	# .so§ §∑
app2=$(basename $(exename))	# .exe.so§ §∑

include ../def.mk

#wine1.1.16§«§œwinegcc§œΩ–Œœ•’•°•§•ÎÃæ§À∞’√œ§«§‚≥»ƒ•ª“§Ú…’§±§Î§ﬂ§ø§§°£
#≥»ƒ•ª“§¨§ §±§Ï§–exe§Ú§ƒ§±§∆foo.exe§»foo.exe.so§ÚΩ–Œœ§∑°¢
#≤ø§´≥»ƒ•ª“§¨§¢§Ï§–foo.ext§»foo.ext.so§ÚΩ–Œœ§π§Î°£
#16∞ æÂ§ §Èwime.exe§Úwime§À —ππ§π§Î°£
winever=$(word 1,$(sort $(shell wine --version) wine-1.1.16))
ifeq ($(winever),wine-1.1.16)	
renamecmd=mv
else
renamecmd=:
endif


$(app):$(objs) $(libwimeutarch) $(solibs)
	$(CC) -o $(app2) $(objs) $(libwimeutarch) $(LDFLAGS)
	$(renamecmd) $(exename) $(app2)

install:
	$(MKDIRP) $(PREFIX)/bin
	$(INSTALL) $(app) $(app2) $(PREFIX)/bin

uninstall:
	$(RM) $(PREFIX)/bin/$(app)
	$(RM) $(PREFIX)/bin/$(app2)
