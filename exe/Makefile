include ../conf.mk

override CFLAGS+=-fno-builtin -mconsole -I..
override LDFLAGS+=-limm32 -lgdi32 -lrt -lpthread
override CC=winegcc

ifeq "$(WOW64)" "1"
override CC:=$(CC32_ENV) $(CC)
override CFLAGS+=-m32
override LDFLAGS+=-m32
endif

ifneq "$(OS)" "Linux"

#/usr/local/include§ђ§ §§§»canna/RK.h§ђ∆…§яєю§ё§м§ §§°£
#§є§ў§∆§ќCFLAGS§Ћ/usr/local/include§т§ƒ§±§л§»/usr/local/include§ќiconv.h§ђї»§п§м§∆§Ј§ё§¶°£
#§»§§§¶§≥§»§«°Ґexe§ќ•≥•у•—•§•лїю§ќ§яlocal§т§ƒ§±§л°£
override CFLAGS+=-I/usr/local/include

#clang§ќ§»§≠§ѕ§≥§м§т§ƒ§±§ §§§»WCHAR§ђ32bit§Ћ§ §√§∆§Ј§ё§¶°£
ifeq "$(USE_CLANG)" "1"
override CFLAGS+=-fno-short-wchar
endif

endif


app=wime
app2=$(app).exe.so
objs=apisup.o canna.o main.o at.o
solibs=../io/libwimeio.so

include ../def.mk

$(objs):override CFLAGS+=-DCALLINGCONV=$(shell ./cdecl)

#wine1.1.16§«§ѕwinegcc§ѕљ–ќѕ•’•°•§•лћЊ§Ћ∞’√ѕ§«§в≥»ƒ•ї“§т…’§±§л§я§њ§§°£
#≥»ƒ•ї“§ђ§ §±§м§–exe§т§ƒ§±§∆foo.exe§»foo.exe.so§тљ–ќѕ§Ј°Ґ
#≤њ§Ђ≥»ƒ•ї“§ђ§Ґ§м§–foo.ext§»foo.ext.so§тљ–ќѕ§є§л°£
#wime.exe§ђљ–ќѕ§µ§м§м§–wime§Ћ —єє§є§л°£
$(app):$(objs) $(libwimeutarch) $(solibs) $(app3)
	$(CC)  -o $(app) $(objs) $(libwimeutarch) $(LDFLAGS)
	[ -e $(app).exe ] && mv $(app).exe $(app)

install:
	$(MKDIRP) $(PREFIX)/bin
	$(INSTALL) $(app) $(app2) $(PREFIX)/bin

uninstall:
	$(RM) $(PREFIX)/bin/$(app)
	$(RM) $(PREFIX)/bin/$(app2)
