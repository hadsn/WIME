override CFLAGS+=-fno-builtin -mconsole -I..
override LDFLAGS+=-limm32 -lgdi32 -lrt -lpthread
override CC=winegcc

ifeq "$(WOW64)" "1"
override CC:=$(CC32_ENV) $(CC)
override CFLAGS+=-m32
override LDFLAGS+=-m32
endif

ifneq "$(OS)" "Linux"

#/usr/local/include§¨§ §§§»canna/RK.h§¨∆…§ŖĻĢ§ř§ž§ §§°£
#§Ļ§Ŕ§∆§őCFLAGS§ň/usr/local/include§Ú§ń§Ī§Ž§»/usr/local/include§őiconv.h§¨Ľ»§Ô§ž§∆§∑§ř§¶°£
#§»§§§¶§≥§»§«°Ęexe§ő•≥•ů•—•§•ŽĽĢ§ő§Ŗlocal§Ú§ń§Ī§Ž°£
override CFLAGS+=-I/usr/local/include

#clang§ő§»§≠§Ō§≥§ž§Ú§ń§Ī§ §§§»WCHAR§¨32bit§ň§ §√§∆§∑§ř§¶°£
ifeq "$(USE_CLANG)" "1"
override CFLAGS+=-fno-short-wchar
endif

endif

winever=$(shell  wine --version|sed -r 's/^[^0-9]+//')
ifeq "$(shell ../vercmp $(winever) -ge 8.2)" "1"
override CFLAGS+=-DHAVE_IMMDEV
endif

app=wime
app2=$(app).exe.so
objs=apisup.o canna.o main.o at.o
solibs=../io/libwimeio.so

include ../def.mk

$(objs):override CFLAGS+=-DCALLINGCONV=$(shell ./cdecl)

#wine1.1.16§«§Ōwinegcc§ŌĹ–őŌ•’•°•§•ŽŐĺ§ňį’√Ō§«§‚≥»ń•Ľ“§Ú…’§Ī§Ž§Ŗ§Ņ§§°£
#≥»ń•Ľ“§¨§ §Ī§ž§–exe§Ú§ń§Ī§∆foo.exe§»foo.exe.so§ÚĹ–őŌ§∑°Ę
#≤Ņ§ę≥»ń•Ľ“§¨§Ę§ž§–foo.ext§»foo.ext.so§ÚĹ–őŌ§Ļ§Ž°£
#wime.exe§¨Ĺ–őŌ§Ķ§ž§ž§–wime§ň —ĻĻ§Ļ§Ž°£
$(app):$(objs) $(libwimeutarch) $(solibs) $(app3)
	$(CC)  -o $(app) $(objs) $(libwimeutarch) $(LDFLAGS)
	[ -e $(app).exe ] && mv $(app).exe $(app)

install:
	$(MKDIRP) $(PREFIX)/bin
	$(INSTALL) $(app) $(app2) $(PREFIX)/bin

uninstall:
	$(RM) $(PREFIX)/bin/$(app)
	$(RM) $(PREFIX)/bin/$(app2)
